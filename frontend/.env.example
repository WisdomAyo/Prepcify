# Public base URL of the prepcify site (used for canonical URLs, sitemap, OG tags).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Browser-facing API base. In dev this points at the Next.js rewrite proxy
# (/api/laravel/* -> Laravel /api/*) so cookies stay first-party.
NEXT_PUBLIC_API_BASE_URL=/api/laravel

# Server-side origin of the Laravel backend, used by the next.config rewrite.
LARAVEL_API_ORIGIN=http://localhost:8000
