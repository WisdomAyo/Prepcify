APP_NAME=Lumio
APP_ENV=local                         # local | staging | production
APP_KEY=                              # Run: php artisan key:generate
APP_DEBUG=true                        # Set false in production
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                       # debug | info | warning | error

# ─── Database ────────────────────────────────────────────────────────────────
# MySQL 8 is required. PostgreSQL 16 supported with config-only change.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lumio
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache / Queue / Session ─────────────────────────────────────────────────
# Set CACHE_STORE=redis and QUEUE_CONNECTION=redis in production when Redis is available.
# The app automatically falls back to "database" drivers at boot if Redis is unreachable.
CACHE_STORE=database                  # database | redis
QUEUE_CONNECTION=database             # database | redis
SESSION_DRIVER=database               # database | redis | cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# ─── Redis ───────────────────────────────────────────────────────────────────
# Only required when CACHE_STORE=redis or QUEUE_CONNECTION=redis.
REDIS_CLIENT=phpredis                 # phpredis | predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
# Default "log" driver writes emails to storage/logs/laravel.log.
# Use "smtp" or "ses" in production.
MAIL_MAILER=log                       # log | smtp | ses | mailgun
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@lumio.ng"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage (Cloudflare R2 / AWS S3 compatible) ────────────────────────────
# Set FILESYSTEM_DISK=s3 in production and fill the AWS_* vars.
# For Cloudflare R2: set AWS_ENDPOINT to your R2 endpoint URL, AWS_DEFAULT_REGION=auto.
# For AWS S3: set AWS_DEFAULT_REGION to your region and leave AWS_ENDPOINT empty.
FILESYSTEM_DISK=local                 # local | s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto               # auto for R2; e.g. us-east-1 for S3
AWS_BUCKET=
AWS_ENDPOINT=                         # e.g. https://<account>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true      # true for R2, false for AWS S3

# ─── Seeding ─────────────────────────────────────────────────────────────────
# Used by SuperadminSeeder. Only runs in non-production unless explicitly invoked.
SEED_SUPERADMIN_EMAIL=admin@lumio.ng
SEED_SUPERADMIN_PASSWORD=

# ─── Sanctum ─────────────────────────────────────────────────────────────────
# Comma-separated domains allowed to use cookie-based Sanctum auth (SPA frontends).
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ─── Payments (Paystack) ─────────────────────────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ─── AI Providers ────────────────────────────────────────────────────────────
# At least one provider key must be set for AI features to work.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── AI Feature Flags ────────────────────────────────────────────────────────
# Set to false to disable individual AI features (returns 503 to clients).
AI_TUTOR_ENABLED=true
AI_EXPLANATIONS_ENABLED=true
AI_STUDY_PLAN_ENABLED=true

# Daily spend cap across all AI providers (USD). 0 = no cap.
AI_INGESTION_DAILY_CAP_USD=0

VITE_APP_NAME="${APP_NAME}"
